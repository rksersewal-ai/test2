# =============================================================================
# FILE: backend/.env.example
# Copy to .env and fill in your values. Never commit .env to git.
#
# PORT REFERENCE (office LAN):
#   8765  → EDMS Django backend   (this app)
#   4173  → EDMS Vite frontend    (this app)
#   8000  → DSC Signer service    (DO NOT USE)
#   5432  → PostgreSQL            (reserved)
#   3306  → MySQL                 (reserved)
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.100

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=edms_db
DB_USER=edms_user
DB_PASSWORD=edms_pass
DB_HOST=127.0.0.1
DB_PORT=5432

# Use SQLite instead (quick dev, no PostgreSQL needed)
# DB_ENGINE=sqlite

# CORS — add LAN frontend origins (port 4173)
CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://192.168.1.100:4173

# Media files directory
MEDIA_ROOT=C:\edms\media

# Celery (optional — for background OCR jobs)
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
