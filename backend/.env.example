# =============================================================================
# FILE: backend/.env.example
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.100

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=edms_db
DB_USER=edms_user
DB_PASSWORD=edms_pass
DB_HOST=127.0.0.1
DB_PORT=5432

# Use SQLite instead (quick dev / no PostgreSQL needed)
# DB_ENGINE=sqlite

# CORS — add LAN frontend IPs
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.100:5173

# Media files directory
MEDIA_ROOT=/opt/edms/media

# Celery (optional — for OCR background jobs)
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
