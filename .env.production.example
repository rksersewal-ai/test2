# =============================================================================
# FILE: .env.production.example
# Copy to .env (at project root D:\plw_edms\.env) and fill ALL values.
# This file is for LAN production deployment (Nginx + Waitress + NSSM).
# DO NOT commit the actual .env file — it is already in .gitignore
# =============================================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=replace-with-a-50-char-random-string-use-python-secrets-module

# Database (PostgreSQL — must be running as Windows Service)
DB_NAME=edms_ldo
DB_USER=edms_user
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery (Redis must be running — download: https://github.com/microsoftarchive/redis/releases)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Waitress WSGI server
# NOTE: Port 8000 is blocked by DSC Signer on office PCs — use 8765
WAITRESS_HOST=127.0.0.1
WAITRESS_PORT=8765
WAITRESS_THREADS=8

# OCR / Tesseract (install from: https://github.com/UB-Mannheim/tesseract/wiki)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_WATCH_FOLDER=D:\plw_edms\ocr_inbox

# LAN access control
# Add your office subnet(s) — comma-separated CIDR ranges
ALLOWED_HOSTS=192.168.1.100,edms.lan,localhost,127.0.0.1
ALLOWED_IP_RANGES=192.168.0.0/16,10.0.0.0/8,127.0.0.1/32
DISABLE_LAN_RESTRICTION=False

# CORS / CSRF — must match your server IP or hostname exactly
CORS_ALLOWED_ORIGINS=https://192.168.1.100,https://edms.lan
CSRF_TRUSTED_ORIGINS=https://192.168.1.100,https://edms.lan

# HTTPS hardening (Nginx handles SSL termination, Django behind proxy)
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
