# Copy this file to .env and fill in values for your environment.
# For local development use config.settings.development.
# For staging / production use config.settings.production.

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=replace-with-a-long-random-secret-key

# Database (PostgreSQL 18)
DB_NAME=edms_ldo
DB_USER=edms_user
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OCR / file processing
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_WATCH_FOLDER=D:\plw_edms\ocr_inbox

# Host / origin controls
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
ALLOWED_IP_RANGES=192.168.0.0/16,10.0.0.0/8,127.0.0.1/32
DISABLE_LAN_RESTRICTION=True

# Reverse-proxy / Waitress
WAITRESS_HOST=127.0.0.1
WAITRESS_PORT=8000
WAITRESS_THREADS=8
USE_X_FORWARDED_HOST=True

# Production HTTPS hardening
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
