# Copy this file to .env and fill in values for your environment

# Django
SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (PostgreSQL 15)
DB_NAME=edms_ldo
DB_USER=edms_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# OCR
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_WATCH_FOLDER=C:\EDMS\ocr_inbox

# LAN Security
ALLOWED_HOSTS=192.168.1.100,localhost
CORS_ALLOWED_ORIGINS=http://192.168.1.100:3000
ALLOWED_IP_RANGES=192.168.0.0/16,10.0.0.0/8

# Production only
# DISABLE_LAN_RESTRICTION=False
