# =============================================================================
# FILE: frontend/.env.example
# Copy to .env.local and adjust for your environment.
# NOTE: Port 8000 is reserved by DSC Signer on office PCs — use 8765 instead.
# =============================================================================

# Dev: Vite proxy forwards /api → Django (no CORS needed)
VITE_API_BASE_URL=/api/v1

# LAN Production (point directly at backend host:port)
# VITE_API_BASE_URL=http://192.168.1.100:8765/api/v1

# If running built frontend from Django (single server mode):
# VITE_API_BASE_URL=/api/v1
