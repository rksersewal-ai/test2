<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS web.config for PLW EDMS + LDO
  Place this file in the IIS site root (e.g. D:\plw_edms_site\web.config)
  
  This config:
  - Proxies all requests to Waitress on localhost:8000
  - Serves /static/ and /media/ directly from disk (bypass Django)
  - Adds security headers at IIS level (backup to Django middleware)
  - Blocks direct access to sensitive files
-->
<configuration>
  <system.webServer>

    <!-- ARR Reverse Proxy to Waitress -->
    <rewrite>
      <rules>
        <!-- Serve static files directly -->
        <rule name="Static Files" stopProcessing="true">
          <match url="^static/(.*)" />
          <action type="None" />
        </rule>
        <!-- Serve media files directly -->
        <rule name="Media Files" stopProcessing="true">
          <match url="^media/(.*)" />
          <action type="None" />
        </rule>
        <!-- Proxy everything else to Waitress -->
        <rule name="Proxy to Django" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
        </rule>
      </rules>
      <outboundRules>
        <rule name="Add Security Headers">
          <match serverVariable="RESPONSE_X_Content_Type_Options" pattern=".*" />
          <action type="Rewrite" value="nosniff" />
        </rule>
      </outboundRules>
    </rewrite>

    <!-- Block access to sensitive files -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".env" />
          <add segment=".git" />
          <add segment="__pycache__" />
          <add segment="migrations" />
          <add segment="tests" />
          <add segment="deployment" />
        </hiddenSegments>
        <fileExtensions allowUnlisted="true">
          <add fileExtension=".py"    allowed="false" />
          <add fileExtension=".pyc"   allowed="false" />
          <add fileExtension=".env"   allowed="false" />
          <add fileExtension=".sqlite3" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- Default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Custom error pages -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" />
      <error statusCode="404" responseMode="Redirect" path="/" />
    </httpErrors>

  </system.webServer>
</configuration>
